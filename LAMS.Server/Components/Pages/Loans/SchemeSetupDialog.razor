@inject IUnitOfWork _unitOfWork
@inject ISnackbar _snackbar

<MudDialog>
    <DialogContent>
        <MudTextField Label="Loan Scheme"  @bind-Value="Model.LoanScheme" Required="true" RequiredError="Loan Scheme is required" />
        <MudTextField Label="Account" @bind-Value="Model.AccountNo" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Success" Variant="Variant.Filled">
            @(_isEdit ? "Update" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public TblLoanScheme Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private bool _isEdit;

    protected override void OnInitialized()
    {
        _isEdit = IsEdit;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.LoanScheme))
            return;

        if (_isEdit)
        {
            try
            {
                await _unitOfWork.Loans.UpdateLoanScheme(Model);
                _snackbar.Add("Loan scheme updated successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                _snackbar.Add($"Error updating loan scheme: {ex.Message}", Severity.Error);
                return;
            }  
      
        }
        else
        {
            try
            {
                await _unitOfWork.Loans.AddLoanScheme(Model);
                _snackbar.Add("Loan scheme added successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                _snackbar.Add($"Error adding loan scheme: {ex.Message}", Severity.Error);
                return;
            }
        }

        MudDialog.Close(DialogResult.Ok(true));
    }
}
