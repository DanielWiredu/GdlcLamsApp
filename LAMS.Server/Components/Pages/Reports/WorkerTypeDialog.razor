<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Select Worker Type
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="modal-body">
            <MudSelect T="string" Label="Worker Type" @bind-Value="workerType">
                <MudSelectItem Value=@("A")>All</MudSelectItem>
                <MudSelectItem Value=@("D")>Daily Workers</MudSelectItem>
                <MudSelectItem Value=@("W")>Weekly Workers</MudSelectItem>
                <MudSelectItem Value=@("M")>Monthly Workers</MudSelectItem>
            </MudSelect>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="MudDialog.Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private string workerType;

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(workerType));
    }
    void Cancel() => MudDialog.Cancel();
}