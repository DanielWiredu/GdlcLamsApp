@page "/tools-users"
@using LAMS.Server.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@* @attribute [Authorize(Roles = "Admin")] *@

@inject IJSRuntime JsRuntime;
@inject UserManager<ApplicationUser> _userManager
@inject ISnackbar _snackbar

<PageBreadcrumb Subtitle="Tools" Title="Users Management" />

<MudPaper Class="pa-4">
    <MudTable Items="_users" Hover="true" Striped="true" Dense="true" Filter="FilterFunc">
        <ToolBarContent>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium" Href="Account/Register"> Add New </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search users..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Email</MudTh>
            <MudTh>Username</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>User Key</MudTh>
            <MudTh>Email Confirmed</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
            @* <MudTh>Lockout Enabled</MudTh> *@
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Username">@context.UserName</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="UserKey">@context.UserKey</MudTd>
            <MudTd DataLabel="Email Confirmed">
                <MudChip T="string" Color="@(context.EmailConfirmed ? Color.Success : Color.Error)"> @(context.EmailConfirmed ? "Yes" : "No") </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.LockoutEnd.HasValue && context.LockoutEnd.Value > DateTimeOffset.Now ? Color.Error : Color.Success)"> 
                    @(context.LockoutEnd.HasValue && context.LockoutEnd.Value > DateTimeOffset.Now ? "Locked" : "Active") </MudChip>
            </MudTd>
            <MudTd>
                @* <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => DisableUser(context.Id)"> Disable </MudButton> *@
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Text">
                    <MudButton OnClick="() => EnableUser(context.Id)">Enable</MudButton>
                    <MudButton OnClick="() => DisableUser(context.Id)">Disable</MudButton>
                </MudButtonGroup>
            </MudTd>
            @* <MudTd DataLabel="Lockout Enabled">
                @(context.LockoutEnabled ? "Yes" : "No")
            </MudTd> *@
            @* <MudTd>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"  OnClick="() => ViewUser(context.Id)"> View </MudButton>
            </MudTd> *@
        </RowTemplate>
    </MudTable>

</MudPaper>

@code {
    private List<ApplicationUser> _users = new();
    private string _searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _users = await _userManager.Users.OrderBy(u => u.Email).ToListAsync();
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error loading users: {ex.Message}", Severity.Error);
        }
    }

    private bool FilterFunc(ApplicationUser user)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return user.Email?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || user.UserName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || user.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    }

    private void ViewUser(string userId)
    {
        _snackbar.Add($"User ID: {userId}", Severity.Info);
        // Later: Navigate to details page
    }

    private async Task EnableUser(string userId)
    {
        try
        {
            var user = await _userManager.FindByIdAsync(userId);
            await _userManager.SetLockoutEndDateAsync(user, DateTimeOffset.UtcNow);

            _users = await _userManager.Users.OrderBy(u => u.Email).ToListAsync();

            _snackbar.Add($"User {user.Email} has been enabled.", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error enabling user: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisableUser(string userId)
    {
        try
        {
            var user = await _userManager.FindByIdAsync(userId);

            await _userManager.SetLockoutEnabledAsync(user, true);
            await _userManager.SetLockoutEndDateAsync(user, DateTimeOffset.MaxValue);

            _users = await _userManager.Users.OrderBy(u => u.Email).ToListAsync();

            _snackbar.Add($"User {user.Email} has been disabled.", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error disabling user: {ex.Message}", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("loadConfig");
            await JsRuntime.InvokeVoidAsync("loadApps");
        }
    }
}
